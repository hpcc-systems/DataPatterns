{
    "compilerOptions": {
        "outDir": "./lib-umd",
        "target": "es2022",
        "module": "es2022",
        "moduleResolution": "node",
        "sourceMap": true,
        "declaration": true,
        "declarationDir": "./types",
        "noEmitOnError": false,
        "strict": true,
        "noImplicitAny": false,
        "lib": [
            "dom",
            "es2022"
        ],
        "types": []
    },
    "include": [
        "src/**/*"
    ]
}