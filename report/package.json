{
  "private": true,
  "name": "datapatterns",
  "version": "0.0.0",
  "type": "module",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "clean": "rimraf --glob lib* types dist res/*.js res/*.map",
    "compile-es6": "tsc --importHelpers true --module es6 --outDir ./lib-es6",
    "compile-es6-watch": "npm run compile-es6 -- -w",
    "compile-umd": "tsc --module umd --outDir ./lib-umd",
    "bundle": "rollup -c",
    "bundle-watch": "npm run bundle -- -w",
    "minimize": "terser dist/index.js -c -m -o res/index.min.js",
    "build": "run-s compile-es6 bundle minimize",
    "watch": "run-p compile-es6-watch bundle-watch",
    "link-hpcc-js": "mklink /J hpcc-js ..\\hpcc-js",
    "lint": "tslint --project . src/**/*.ts",
    "docs": "typedoc --options tdoptions.json .",
    "update-major": "npx -y npm-check-updates -u",
    "update": "npx -y npm-check-updates -u -t minor"
  },
  "dependencies": {
    "@hpcc-js/api": "3.5.4",
    "@hpcc-js/chart": "3.8.4",
    "@hpcc-js/common": "3.8.4",
    "@hpcc-js/comms": "3.17.4",
    "@hpcc-js/ddl-shim": "3.4.4",
    "@hpcc-js/dgrid2": "3.7.4",
    "@hpcc-js/html": "3.4.4",
    "@hpcc-js/layout": "3.6.4",
    "@hpcc-js/other": "3.6.4",
    "@hpcc-js/phosphor": "3.8.2",
    "@hpcc-js/react": "3.5.4",
    "@hpcc-js/util": "3.6.4"
  },
  "devDependencies": {
    "@lumino/algorithm": "2.0.4",
    "@lumino/commands": "2.3.3",
    "@lumino/messaging": "2.0.4",
    "@lumino/widgets": "2.8.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "npm-run-all": "4.1.5",
    "preact": "10.29.2",
    "rimraf": "6.1.3",
    "rollup": "4.62.2",
    "terser": "5.48.0",
    "tslib": "2.8.1",
    "typescript": "6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hpcc-systems/DataPatterns.git"
  },
  "author": "",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/hpcc-systems/DataPatterns/issues"
  },
  "homepage": "https://github.com/hpcc-systems/DataPatterns"
}